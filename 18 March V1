function buildTable(tbodyId,rows,isIndirect){
  const tbody=document.getElementById(tbodyId);
  rows.forEach((r,idx)=>{
    const rowCls=r.fatal?'hi-fatal':r.mass?'hi-mass':'';
    const id=tbodyId+'-'+idx;
    if(isIndirect){
      tbody.innerHTML+=`<tr class="row-trigger ${rowCls}" onclick="toggleRow('${id}')"><td><span class="toggle-icon" id="icon-${id}">&#9658;</span>${r.date}</td><td>${r.loc}</td><td>${r.fatal?'<b>'+r.summary+'</b>':r.summary}</td><td></td></tr><tr class="row-detail" id="detail-${id}"><td colspan="4">${r.detail}</td></tr>`;
    } else {
      tbody.innerHTML+=`<tr class="row-trigger ${rowCls}" onclick="toggleRow('${id}')"><td><span class="toggle-icon" id="icon-${id}">&#9658;</span>${r.date}</td><td>${r.loc}</td><td style="font-size:11px">${r.mun}</td><td style="font-size:11px">${r.fatal?'<b>'+r.cas+'</b>':r.cas}</td><td></td></tr><tr class="row-detail" id="detail-${id}"><td colspan="5">${r.detail}</td></tr>`;
    }
  });
}

function toggleRow(id){
  const d=document.getElementById('detail-'+id);
  const ic=document.getElementById('icon-'+id);
  const o=d.classList.toggle('open');
  ic.classList.toggle('open',o);
}

