function buildTable(tbodyId,rows,isIndirect){
  var tbody=document.getElementById(tbodyId);
  rows.forEach(function(r,idx){
    var rc=r.fatal?'hi-fatal':r.mass?'hi-mass':'';
    var id=tbodyId+'-'+idx;
    if(isIndirect){
      tbody.innerHTML+='<tr class="row-trigger '+rc+'" onclick="toggleRow(\''+id+'\')"><td><span class="toggle-icon" id="icon-'+id+'">&#9658;</span>'+r.date+'</td><td>'+r.loc+'</td><td>'+(r.fatal?'<b>'+r.summary+'</b>':r.summary)+'</td><td></td></tr><tr class="row-detail" id="detail-'+id+'"><td colspan="4">'+r.detail+'</td></tr>';
    }else{
      tbody.innerHTML+='<tr class="row-trigger '+rc+'" onclick="toggleRow(\''+id+'\')"><td><span class="toggle-icon" id="icon-'+id+'">&#9658;</span>'+r.date+'</td><td>'+r.loc+'</td><td style="font-size:11px">'+r.mun+'</td><td style="font-size:11px">'+(r.fatal?'<b>'+r.cas+'</b>':r.cas)+'</td><td></td></tr><tr class="row-detail" id="detail-'+id+'"><td colspan="5">'+r.detail+'</td></tr>';
    }
  });
}
function toggleRow(id){var d=document.getElementById('detail-'+id);var ic=document.getElementById('icon-'+id);var o=d.classList.toggle('open');ic.classList.toggle('open',o);}
buildTable('directTbody',directRows,false);
buildTable('indirectTbody',indirectRows,true);

// MAP
var ns='http://www.w3.org/2000/svg';
var mapG=document.getElementById('mapMarkers');
var tip=document.getElementById('mapTip');
function renderMarkers(rows,type){
  rows.forEach(function(r){
    var col=type==='direct'?'#C43A3A':'#BA7517';
    var g=document.createElementNS(ns,'g');g.style.cursor='pointer';
    var x=r.mx,y=r.my,sz=r.ms;
    if(r.fatal){var ring=document.createElementNS(ns,'circle');ring.setAttribute('cx',x);ring.setAttribute('cy',y);ring.setAttribute('r',sz+8);ring.setAttribute('fill','none');ring.setAttribute('stroke',col);ring.setAttribute('stroke-width','2');ring.setAttribute('stroke-dasharray','3 2.5');ring.setAttribute('opacity','0.45');g.appendChild(ring);}
    if(sz>=14){var halo=document.createElementNS(ns,'circle');halo.setAttribute('cx',x);halo.setAttribute('cy',y);halo.setAttribute('r',sz+6);halo.setAttribute('fill',col);halo.setAttribute('opacity','0.1');g.appendChild(halo);}
    var c=document.createElementNS(ns,'circle');c.setAttribute('cx',x);c.setAttribute('cy',y);c.setAttribute('r',sz);c.setAttribute('fill',col);c.setAttribute('opacity',type==='direct'?'0.88':'0.78');c.setAttribute('stroke','white');c.setAttribute('stroke-width','1.2');g.appendChild(c);
    if(sz>=18&&r.fatal){var lbl=document.createElementNS(ns,'text');lbl.setAttribute('x',x);lbl.setAttribute('y',y+4);lbl.setAttribute('text-anchor','middle');lbl.setAttribute('font-size','10');lbl.setAttribute('font-weight','700');lbl.setAttribute('fill','white');lbl.setAttribute('pointer-events','none');var km=r.cas.match(/(\d+) killed/);if(km)lbl.textContent=km[1]+'x';g.appendChild(lbl);}
    var tl=type==='direct'?'Direct warhead impact':'Intercept debris / indirect';
    var tc2=type==='direct'?'background:#FCEBEB;color:#791F1F':'background:#FAEEDA;color:#633806';
    var cas=type==='direct'?r.cas:r.summary;var mn=type==='direct'?r.mun:'';
    g.addEventListener('click',function(e){
      e.stopPropagation();
      tip.innerHTML='<div style="font-size:10px;color:var(--text3);margin-bottom:2px">'+r.date+'</div><div style="font-size:12px;font-weight:600;margin-bottom:3px">'+r.loc+'</div><span style="display:inline-block;font-size:9px;font-weight:600;padding:1px 6px;border-radius:3px;margin-bottom:5px;'+tc2+'">'+tl+'</span>'+(mn?'<div style="font-size:11px;font-weight:600;color:var(--text);margin-bottom:2px">'+mn+'</div>':'')+'<div style="font-size:11px;color:var(--text2);line-height:1.45;margin-bottom:4px">'+cas+'</div><div style="font-size:10px;color:var(--text3);border-top:.5px solid var(--border);padding-top:4px;line-height:1.5">'+r.detail.substring(0,200)+(r.detail.length>200?'\u2026':'')+'</div>';
      tip.classList.add('vis');var lx=e.clientX+14,ly=e.clientY-10,tw=275,th=170;
      if(lx+tw>window.innerWidth) lx=e.clientX-tw-10;if(ly+th>window.innerHeight) ly=e.clientY-th-10;
      tip.style.left=lx+'px';tip.style.top=ly+'px';
    });
    g.addEventListener('mouseenter',function(){c.setAttribute('opacity','1');});
    g.addEventListener('mouseleave',function(){c.setAttribute('opacity',type==='direct'?'0.88':'0.78');});
    mapG.appendChild(g);
  });
}
document.addEventListener('click',function(){tip.classList.remove('vis');});
renderMarkers(indirectRows,'debris');
renderMarkers(directRows,'direct');

// ZOOM & PAN
var vp=document.getElementById('mapVP');var canvas=document.getElementById('mapCanvas');
var SVG_W=560,SVG_H=860;var scale=0.78,minScale=0.42,maxScale=4;var tx=0,ty=0;
function clamp(){var vw=vp.offsetWidth||800,vh=vp.offsetHeight||600;tx=Math.max(Math.min(0,vw-SVG_W*scale),Math.min(0,tx));ty=Math.max(Math.min(0,vh-SVG_H*scale),Math.min(0,ty));}
function applyT(){canvas.style.transform='translate('+tx+'px,'+ty+'px) scale('+scale+')';}
function initView(){var vw=vp.offsetWidth||800,vh=vp.offsetHeight||600;scale=Math.min(vw/SVG_W,vh/SVG_H)*0.95;tx=(vw-SVG_W*scale)/2;ty=Math.max(vh-SVG_H*scale,-Math.max(0,284*scale-vh*0.3));clamp();applyT();}
initView();
function zoomAt(cx,cy,f){var ns2=Math.max(minScale,Math.min(maxScale,scale*f));tx=cx-(cx-tx)*(ns2/scale);ty=cy-(cy-ty)*(ns2/scale);scale=ns2;clamp();applyT();}
document.getElementById('zoomIn').addEventListener('click',function(){zoomAt(vp.offsetWidth/2,vp.offsetHeight/2,1.35);});
document.getElementById('zoomOut').addEventListener('click',function(){zoomAt(vp.offsetWidth/2,vp.offsetHeight/2,1/1.35);});
document.getElementById('resetView').addEventListener('click',function(){initView();});
vp.addEventListener('wheel',function(e){e.preventDefault();var r=vp.getBoundingClientRect();zoomAt(e.clientX-r.left,e.clientY-r.top,e.deltaY<0?1.12:1/1.12);},{passive:false});
var drag=false,dsx=0,dsy=0,dstx=0,dsty=0;
vp.addEventListener('mousedown',function(e){if(e.button!==0)return;drag=true;dsx=e.clientX;dsy=e.clientY;dstx=tx;dsty=ty;e.preventDefault();});
window.addEventListener('mousemove',function(e){if(!drag)return;tx=dstx+(e.clientX-dsx);ty=dsty+(e.clientY-dsy);clamp();applyT();});
window.addEventListener('mouseup',function(){drag=false;});
var lDist=null,pMx=0,pMy=0,ptx=0,pty=0,psc=1;
vp.addEventListener('touchstart',function(e){if(e.touches.length===2){lDist=Math.hypot(e.touches[0].clientX-e.touches[1].clientX,e.touches[0].clientY-e.touches[1].clientY);var r=vp.getBoundingClientRect();pMx=(e.touches[0].clientX+e.touches[1].clientX)/2-r.left;pMy=(e.touches[0].clientY+e.touches[1].clientY)/2-r.top;psc=scale;ptx=tx;pty=ty;}else if(e.touches.length===1){dsx=e.touches[0].clientX;dsy=e.touches[0].clientY;dstx=tx;dsty=ty;}},{passive:true});
vp.addEventListener('touchmove',function(e){e.preventDefault();if(e.touches.length===2&&lDist){var d=Math.hypot(e.touches[0].clientX-e.touches[1].clientX,e.touches[0].clientY-e.touches[1].clientY);var ns2=Math.max(minScale,Math.min(maxScale,psc*(d/lDist)));tx=pMx-(pMx-ptx)*(ns2/psc);ty=pMy-(pMy-pty)*(ns2/psc);scale=ns2;clamp();applyT();}else if(e.touches.length===1){tx=dstx+(e.touches[0].clientX-dsx);ty=dsty+(e.touches[0].clientY-dsy);clamp();applyT();}},{passive:false});
vp.addEventListener('touchend',function(){lDist=null;},{passive:true});
</script>
