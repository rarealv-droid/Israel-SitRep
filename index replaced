<script>
// Dark mode detection for chart axis colours
const dark = window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches;
const gridCol = dark ? 'rgba(200,198,190,0.1)' : 'rgba(120,118,110,0.1)';
const tickCol = dark ? '#a8a69e' : '#6b6a64';

// ── DAILY WAVES CHART ──
const days = [
  ['28 Feb',45,0],['1 Mar',38,0],['2 Mar',18,12],['3 Mar',14,23],
  ['4 Mar',13,47],['5 Mar',11,21],['6 Mar',11,43],['7 Mar',10,46],
  ['8 Mar',10,31],['9 Mar',10,32],['10 Mar',10,34],['11 Mar',9,34],
  ['12 Mar',10,30],['13 Mar',10,28],['14 Mar',9,28],['15 Mar',9,28],
];
new Chart(document.getElementById('dailyChart'), {
  type: 'bar',
  data: {
    labels: days.map(d => d[0]),
    datasets: [
      { label:'Iran', data:days.map(d=>d[1]), backgroundColor:'#185FA5', borderRadius:2, stack:'s' },
      { label:'Hezbollah', data:days.map(d=>d[2]), backgroundColor:'#C43A3A', borderRadius:2, stack:'s' }
    ]
  },
  options: {
    responsive:true, maintainAspectRatio:false,
    plugins:{ legend:{display:false}, tooltip:{mode:'index'} },
    scales:{
      x:{ stacked:true, ticks:{font:{size:10}, color:tickCol, autoSkip:false, maxRotation:45}, grid:{display:false} },
      y:{ stacked:true, ticks:{font:{size:10}, color:tickCol}, grid:{color:gridCol}, title:{display:true, text:'Waves', font:{size:10}, color:tickCol} }
    }
  }
